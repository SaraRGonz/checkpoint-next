generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id
  name          String?
  email         String?       @unique
  image         String?
  imagePosition String?
  createdAt     DateTime      @default(now())

  games         Game[]
  playthroughs  Playthrough[]

  @@map("users")
}

model Platform {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  
  games        Game[]
  playthroughs Playthrough[] 

  @@map("platforms")
}

model Genre {
  id           String   @id @default(cuid())
  name         String   @unique
  games        Game[] 

  @@map("genres")
}

model Game {
  id            String        @id @default(uuid())
  title         String
  coverUrl      String?
  coverPosition String?
  releaseYear   Int?
  rawgId        Int?
  rating        Int?
  review        String?       @db.Text
  status        Status        @default(QUEUE)
  addedAt       DateTime      @default(now())
  updatedAt     DateTime?     @updatedAt

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  platformId    String
  platform      Platform      @relation(fields: [platformId], references: [id], onDelete: Restrict)
  genres        Genre[]
  playthroughs  Playthrough[] 

  @@map("games")
}

model Playthrough {
  id            String    @id @default(uuid())
  startDate     DateTime  @default(now())
  endDate       DateTime?
  status        Status    @default(PLAYING)
  rating        Int?
  notes         String?   @db.Text

  characterName String?   
  serverName    String?
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  gameId        String
  game          Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  platformId    String    
  platform      Platform  @relation(fields: [platformId], references: [id], onDelete: Restrict)

  @@map("playthroughs")
}

enum Status {
  WISHLIST
  COMPLETED
  PLAYING
  QUEUE
  DROPPED
}